# dcss-server-install — example .env
# Copy to .env (or run ./install.sh) and edit. Re-deploy with `./run.sh banner`
# for non-build changes, `./run.sh game` for image-affecting changes.

# ── Server identity (REQUIRED) ──────────────────────────────────────────────
SERVER_ABBR=MYSRV                           # 3-6 letters, shown in lobby + emails
SERVER_URL=https://crawl.example.com        # full base URL with scheme
SERVER_REGION_SHORT="Eastern US"             # shown in latency widget + dgamelaunch
SERVER_REGION="Eastern US"                   # used by Discord bot embeds (same value usually)
SERVER_ADMIN=                               # your handle, e.g. "yourname#1234". Blank = no contact line.
SSH_PORT=222                                # external port for SSH play

# ── SMTP (optional — Forgot Password emails) ───────────────────────────────
# Any STARTTLS provider on port 587. AWS SES, Mailgun, Postmark, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="DCSS WebTiles <admin@crawl.example.com>"
NOTIFY_EMAIL=                               # alerts go here (release-checker, etc.)

# ── Discord bot (optional — opt-in via `--profile discord`) ────────────────
# Create at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=
DISCORD_INVITE=                             # invite code, shown in password-reset email

# ── Imported accounts (optional) ───────────────────────────────────────────
# Set if you imported users from another DCSS server, so the registration
# error message tells people to log in with their old password.
IMPORT_SOURCE_NAME=                         # e.g. CAO, CDI
IMPORT_SOURCE_URL=                          # e.g. crawl.akrasiac.org
IMPORT_DATE=                                # e.g. "April 25, 2026"
DB_MIN_USERS=0                              # safety check; bump if you imported a known user count

# ── Build flags (advanced) ─────────────────────────────────────────────────
# Default: 0.34 + trunk only. Set to Dockerfile.game.full to also build
# 0.30-0.33 (run `bash scripts/build-frozen.sh` first, see docs/upgrading.md).
DOCKERFILE_GAME=Dockerfile.game

# ── Cross-server widget (optional — for multi-server admins) ───────────────
# Show "[CRG]: 30ms ↗" link in the lobby banner pointing to your other server.
# OTHER_SERVER_NAME=
# OTHER_SERVER_URL=https://crawl-west.example.com
# OTHER_SERVER_REGION="US-West"
