<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>__SERVER_ABBR__ Lobby Preview</title>
<style>
  /* ── Base: match WebTiles terminal look ── */
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: #000;
    color: #b0b0b0;
    font-family: "DejaVu Sans Mono", "Courier New", monospace;
    font-size: 16px;
    line-height: 1.4;
    padding: 10px;
  }
  a { color: #5fd7ff; text-decoration: underline; }
  a:visited { color: #5fd7ff; }
  a:hover { color: #fff; }

  /* ── Header ── */
  .lobby-header { margin-bottom: 4px; }
  .lobby-header b { color: #fff; }
  .lobby-header-sub { color: #888; font-size: 0.88em; }

  /* ── Latency ── */
  .bn-latency { font-size: 0.85em; }
  .bn-latency.good { color: #5b5; }
  .bn-latency.ok { color: #dbb154; }
  .bn-latency.poor { color: #d44; }

  /* ── Top-right login area ── */
  .lobby-login {
    float: right;
    color: #b0b0b0;
  }
  .lobby-login a { color: #5fd7ff; }

  /* ── Banner cards ── */
  #rgg-banner { margin: 8px 0 6px; font-size: 0.92em; line-height: 1.6; width: 100%; }
  #rgg-banner .bn-row { display: flex; flex-wrap: wrap; gap: 8px 16px; align-items: stretch; margin-bottom: 6px; width: 100%; }
  #rgg-banner .bn-card {
    flex: 1 1 0;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 4px;
    padding: 6px 10px;
    min-width: 200px;
  }
  #rgg-banner .bn-card-header {
    font-size: 0.85em;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #888;
    margin-bottom: 3px;
  }
  #rgg-banner .bn-win { border-left: 3px solid #5b5; }
  #rgg-banner .bn-death { border-left: 3px solid #d44; }
  #rgg-banner .bn-stats { border-left: 3px solid #dbb154; }
  #rgg-banner .bn-player { color: #dbb154; font-weight: bold; }
  #rgg-banner .bn-combo { color: #aaa; }
  #rgg-banner .bn-detail { color: #999; font-size: 0.88em; }
  #rgg-banner .bn-win-text { color: #6c6; }
  #rgg-banner .bn-death-text { color: #d66; font-size: 0.88em; }
  #rgg-banner .bn-stat-num { color: #dbb154; font-weight: bold; }
  #rgg-banner .bn-god { color: #b8a0d0; }
  #rgg-banner .bn-empty { color: #666; font-style: italic; font-size: 0.88em; }
  #rgg-banner .bn-morgue-link { font-size: 0.82em; }
  #rgg-banner .bn-motd { border-left: 3px solid #5fd7ff; }
  #rgg-banner .bn-motd-text { color: #5fd7ff; font-size: 0.88em; }
  #rgg-banner .bn-newest-name { color: #fff; font-weight: bold; }
  #rgg-banner a { color: #5fd7ff; }
  #rgg-banner a:hover { color: #fff; }

  /* ── Nav links ── */
  .lobby-nav { margin-top: 10px; color: #888; }
  .lobby-nav a { color: #5fd7ff; }

  /* ── Greeting ── */
  .lobby-greeting { margin-top: 4px; }

  /* ── Play section ── */
  .lobby-play { margin-top: 8px; }
  .lobby-play a { color: #5fd7ff; }
  .lobby-play .version-label { color: #888; display: inline-block; width: 160px; text-align: right; margin-right: 8px; }
  .lobby-play .older-toggle { color: #43A047; cursor: pointer; margin-top: 4px; }
  .lobby-older { margin-top: 4px; display: none; }
  .lobby-older.show { display: block; }

  /* ── Game table ── */
  .lobby-games { margin-top: 16px; }
  .lobby-games-header { text-align: center; color: #b0b0b0; margin-bottom: 4px; }
  .lobby-games table { border-collapse: collapse; width: 100%; font-size: 0.92em; }
  .lobby-games th { color: #888; text-align: left; padding: 2px 8px 2px 0; border-bottom: 1px solid #333; }
  .lobby-games td { padding: 2px 8px 2px 0; }
  .lobby-games .col-user a { color: #5fd7ff; }
  .lobby-games .col-game { color: #888; }
  .lobby-games .col-char { color: #b0b0b0; text-align: right; padding-right: 12px; }
  .lobby-games .col-place { color: #b0b0b0; }
  .lobby-games .col-turn { color: #888; text-align: right; padding-right: 12px; }
  .lobby-games .col-time { color: #888; }
  .lobby-games .col-god { color: #b8a0d0; }
  .lobby-games .col-idle { color: #888; }
  .lobby-games .col-specs { color: #888; }
  .lobby-games .col-milestone { color: #888; }
</style>
