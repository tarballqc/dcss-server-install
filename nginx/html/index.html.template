<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>DCSS — __SERVER_HOST__</title>
<meta name="description" content="Play Dungeon Crawl Stone Soup in your browser. Free, open-source roguelike — no download required.">
<meta property="og:title" content="Dungeon Crawl Stone Soup — WebTiles Server">
<meta property="og:description" content="Descend into the dungeon, claim the Orb of Zot, and escape alive. Play free in your browser.">
<meta property="og:type" content="website">
<meta property="og:url" content="__SERVER_URL__/">
<meta property="og:site_name" content="__SERVER_HOST__">
<meta name="theme-color" content="#dbb154">
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>💀</text></svg>">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cinzel+Decorative:wght@400;700&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --void:       #08080a;
    --stone:      #0e0e10;
    --stone2:     #141416;
    --stone3:     #1a1a1d;
    --border:     #2c2a2e;
    --text:       #c5c1ba;
    --text-dim:   #8a8680;
    --text-bright:#e8e4de;
    --gold:       #dbb154;
    --gold-bright:#f0c850;
    --gold-dim:   #9a7a30;
    --ember:      #d05540;
    --cyan:       #5cc4b4;
    --blue:       #5a82c0;
    --green:      #6aad58;
    --purple:     #9a6eb8;
    --muted:      #605c56;
    --font-display: 'Cinzel', 'Georgia', serif;
    --font-decorative: 'Cinzel Decorative', 'Cinzel', serif;
    --font-mono:  'JetBrains Mono', 'Courier New', monospace;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--void);
    background-image:
      radial-gradient(ellipse at 20% 50%, rgba(219,177,84,.015) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(92,196,180,.01) 0%, transparent 50%);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 15px;
    line-height: 1.7;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    -webkit-font-smoothing: antialiased;
  }
  a { color: var(--cyan); text-decoration: none; transition: color .2s; }
  a:hover { color: var(--gold-bright); }

  /* ── Portal Nav (standardized across all roguelikes.gg sites, 36px) ──── */
  .portal-nav {
    --nav-h: 36px;
    display: flex;
    align-items: center;
    padding: 0 2rem;
    height: var(--nav-h);
    background: rgba(6, 6, 8, .92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 1000;
  }
  .portal-brand {
    font-family: var(--font-decorative);
    font-size: 11px;
    color: var(--text-dim) !important;
    letter-spacing: 3px;
    padding: 0 1.5rem 0 0;
    margin-right: 1rem;
    border-right: 1px solid var(--border);
    text-transform: uppercase;
  }
  .portal-brand:hover { color: var(--text-bright) !important; }
  .portal-games {
    display: flex;
    margin-right: auto;
  }
  .portal-games a {
    color: var(--text-dim);
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 0 1rem;
    line-height: var(--nav-h);
    border-bottom: 2px solid transparent;
    transition: color .2s, border-color .2s;
  }
  .portal-games a:hover { color: var(--text-bright); border-bottom-color: var(--gold-dim); }
  .portal-games a.active { color: var(--gold); border-bottom-color: var(--gold); }
  .portal-local {
    display: flex;
  }
  .portal-local a {
    color: var(--text-dim);
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 0 1rem;
    line-height: var(--nav-h);
    border-bottom: 2px solid transparent;
    transition: color .2s, border-color .2s;
  }
  .portal-local a:hover { color: var(--text-bright); border-bottom-color: var(--gold-dim); }
  .portal-local a.active { color: var(--text-bright); border-bottom-color: var(--gold); }
  .portal-local a.play-link { color: var(--gold); }
  .portal-local a.play-link:hover { color: var(--gold-bright); border-bottom-color: var(--gold); }

  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .hero {
    background: radial-gradient(ellipse at 50% 80%, rgba(219,177,84,.06) 0%, var(--stone) 60%);
    border-bottom: 1px solid var(--border);
    border-image: linear-gradient(90deg, transparent, var(--gold-dim), transparent) 1;
    padding: 2.5rem 2rem 2rem;
    text-align: center;
  }
  .hero-title {
    font-family: var(--font-decorative);
    font-size: clamp(1.2rem, 3vw, 1.6rem);
    font-weight: 700;
    color: var(--gold);
    line-height: 1.2;
    letter-spacing: 3px;
  }
  .hero-sub {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--text-dim);
    letter-spacing: 2px;
    margin-top: .5rem;
  }

  /* ── Content ─────────────────────────────────────────────────────────── */
  .content {
    max-width: 920px;
    margin: 0 auto;
    padding: 0 2rem;
    width: 100%;
    flex: 1;
  }

  .section-title {
    font-family: var(--font-display);
    color: var(--text-bright);
    border-bottom: 1px solid var(--border);
    border-left: 2px solid var(--gold-dim);
    padding: .4rem 0 .4rem .8rem;
    margin: 2.5rem 0 1rem;
    font-size: .9rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* ── Feature cards ───────────────────────────────────────────────────── */
  .features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-top: 1.5rem;
  }
  .feature {
    background: var(--stone);
    padding: 1.2rem 1rem;
    transition: background .2s, transform .2s, box-shadow .2s;
    text-align: center;
    position: relative;
  }
  .feature::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,.06), transparent);
  }
  .feature:hover { background: var(--stone2); transform: translateY(-2px); box-shadow: 0 4px 20px rgba(0,0,0,.4), inset 0 1px 0 rgba(255,255,255,.03); }
  .feature-play {
    background: rgba(219, 177, 84, .06);
    border-right: 1px solid var(--gold-dim);
  }
  .feature-play .feature-icon { font-size: 1.6rem; }
  .feature-play .feature-name { color: var(--gold); }
  .feature-play .feature-link { color: var(--gold); }
  .feature-play:hover { background: rgba(219, 177, 84, .12); box-shadow: 0 4px 20px rgba(219,177,84,.15), inset 0 1px 0 rgba(219,177,84,.1); }
  .feature-icon {
    font-size: 1.3rem;
    display: block;
    margin-bottom: .4rem;
  }
  .feature-name {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    color: var(--text-bright);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: .3rem;
  }
  .feature-desc {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.5;
    margin-bottom: .6rem;
  }
  .feature-link {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 1px;
    color: var(--cyan);
    transition: color .2s;
  }
  .feature-link:hover { color: var(--gold-bright); }
  .feature-link::after { content: ' \2192'; }

  /* ── Live games ─────────────────────────────────────────────────────── */
  .live-header {
    display: flex;
    align-items: baseline;
    gap: .6rem;
  }
  .live-header .section-title { flex: 1; }
  .live-count {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    white-space: nowrap;
  }
  .live-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    background: var(--green);
    border-radius: 50%;
    margin-right: 4px;
    animation: pulse 2s ease infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: .4; }
  }
  .live-table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid var(--border);
    font-size: 13px;
  }
  .live-table th {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--muted);
    text-align: left;
    padding: .5rem .6rem;
    border-bottom: 1px solid var(--border);
    background: var(--stone);
  }
  .live-table td {
    padding: .4rem .6rem;
    border-bottom: 1px solid rgba(44, 42, 46, .3);
    color: var(--text);
  }
  .live-table tr:hover td { background: var(--stone2); }
  .live-table .col-user { color: var(--gold); }
  .live-table .col-user a { color: var(--gold); }
  .live-table .col-user a:hover { color: var(--gold-bright); }
  .live-table .col-char { color: var(--cyan); }
  .live-table .col-place { color: var(--text-bright); }
  .live-table .col-god { color: var(--purple); }
  .live-table .col-milestone { color: var(--text-dim); font-size: 12px; }
  .live-table .col-specs { color: var(--muted); text-align: center; }
  .live-table .col-idle { color: var(--muted); }
  .live-empty {
    text-align: center;
    padding: 2.5rem 1.5rem;
    color: var(--muted);
    font-size: 14px;
    border: 1px solid var(--border);
    background: var(--stone);
    background-image: radial-gradient(ellipse at 50% 50%, rgba(219,177,84,.03) 0%, transparent 70%);
  }
  .live-empty-icon {
    font-size: 1.5rem;
    display: block;
    margin-bottom: .5rem;
    opacity: .3;
  }
  @media (max-width: 768px) {
    .live-table .col-milestone,
    .live-table .col-god,
    .live-table .col-idle { display: none; }
    .live-table th:nth-child(n+6),
    .live-table td:nth-child(n+6) { display: none; }
  }
  @media (max-width: 480px) {
    .live-table .col-turn,
    .live-table .col-specs { display: none; }
    .live-table th:nth-child(4),
    .live-table td:nth-child(4),
    .live-table th:nth-child(7),
    .live-table td:nth-child(7) { display: none; }
  }

  /* ── About ───────────────────────────────────────────────────────────── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .about-block {
    background: var(--stone);
    padding: 1.5rem;
  }
  .about-block h3 {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    color: var(--gold);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: .6rem;
  }
  .about-block p {
    font-size: 14px;
    color: var(--text);
    line-height: 1.7;
  }
  .about-block p em {
    color: var(--text-bright);
    font-style: normal;
  }

  /* ── How to play ─────────────────────────────────────────────────────── */
  .how-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .how-col {
    background: var(--stone);
    padding: 1.5rem;
  }
  .how-col h3 {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    color: var(--gold);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: .6rem;
  }
  .how-list { list-style: none; }
  .how-list li {
    font-size: 14px;
    color: var(--text);
    padding: .4rem 0;
    display: flex;
    align-items: baseline;
    gap: .6rem;
    border-bottom: 1px solid rgba(44, 42, 46, .5);
  }
  .how-list li:last-child { border-bottom: none; }
  .step-num {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    color: var(--gold-dim);
    min-width: 1.2rem;
  }
  .how-list kbd {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--gold);
    background: var(--stone3);
    border: 1px solid var(--border);
    padding: 1px 6px;
    min-width: 2rem;
    text-align: center;
    display: inline-block;
  }
  .key-desc {
    color: var(--text);
    flex: 1;
  }

  /* ── Gods ─────────────────────────────────────────────────────────────── */
  .gods {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .gods-inner {
    display: contents;
  }
  .god {
    background: var(--stone);
    padding: .8rem .3rem;
    text-align: center;
    transition: background .2s;
  }
  .god:hover { background: var(--stone2); }
  .god-glyph {
    font-family: var(--font-decorative);
    font-size: 1.1rem;
    font-weight: 700;
    width: 2.2rem;
    height: 2.2rem;
    line-height: 2.2rem;
    margin: 0 auto .4rem;
    border: 1px solid currentColor;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform .2s, box-shadow .2s;
  }
  .god:hover .god-glyph {
    transform: scale(1.1);
    box-shadow: 0 0 8px currentColor;
  }
  .god-name {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--muted);
    transition: color .2s;
  }
  .god:hover .god-name { color: var(--text); }

  .g-good  .god-glyph { color: var(--gold); }
  .g-neutral .god-glyph { color: var(--cyan); }
  .g-evil  .god-glyph { color: var(--ember); }
  .g-chaos .god-glyph { color: var(--purple); }
  /* ── Species showcase ──────────────────────────────────────────────── */
  .species-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .species {
    background: var(--stone);
    padding: 1rem;
    transition: background .2s;
  }
  .species:hover { background: var(--stone2); }
  .species-name {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    color: var(--cyan);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: .3rem;
  }
  .species-desc {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.5;
  }

  /* ── Why DCSS ──────────────────────────────────────────────────────── */
  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .why-item {
    background: var(--stone);
    padding: 1.2rem 1.5rem;
  }
  .why-item h3 {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    color: var(--gold);
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: .4rem;
  }
  .why-item p {
    font-size: 13px;
    color: var(--text);
    line-height: 1.6;
  }

  /* ── Version badge ─────────────────────────────────────────────────── */
  .version-badge {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
    text-align: center;
    padding: .8rem;
    border: 1px solid var(--border);
    background: var(--stone);
    margin-top: 1rem;
  }
  .version-badge span { color: var(--gold); }

  /* ── Lore ─────────────────────────────────────────────────────────────── */
  .lore {
    border-left: 2px solid var(--gold-dim);
    padding: 1rem 1.5rem;
    margin: 2rem 0;
  }
  .lore-quote {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 400;
    font-style: italic;
    color: var(--text);
    line-height: 1.7;
    margin-bottom: .3rem;
  }
  .lore-attrib {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  /* ── Footer ──────────────────────────────────────────────────────────── */
  footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 920px;
    margin: 0 auto;
    width: 100%;
  }
  .footer-left {
    font-family: var(--font-decorative);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 2px;
  }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-links a {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
  }
  .footer-links a:hover { color: var(--gold); }

  /* ── Animations ──────────────────────────────────────────────────────── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .hero          { animation: fadeUp .4s ease both; }
  .features      { animation: fadeUp .4s ease .1s both; }
  .live-section  { animation: fadeUp .4s ease .12s both; }
  .about-grid    { animation: fadeUp .4s ease .15s both; }
  .how-grid      { animation: fadeUp .4s ease .2s both; }
  .gods          { animation: fadeUp .4s ease .25s both; }
  .lore          { animation: fadeUp .4s ease .3s both; }
  .section-title { animation: fadeUp .3s ease .1s both; }

  /* ── Responsive ──────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .portal-nav { padding: 0 .5rem; flex-wrap: wrap; }
    .portal-brand { display: none; }
    .portal-games a, .portal-local a { padding: .8rem .6rem; font-size: 10px; letter-spacing: 1px; }
    .portal-local { display: none; }
    .features { grid-template-columns: 1fr; }
    .about-grid, .how-grid { grid-template-columns: 1fr; }
    .gods { grid-template-columns: repeat(5, 1fr); }
    .species-grid { grid-template-columns: repeat(2, 1fr); }
    .why-grid { grid-template-columns: 1fr; }
    .content { padding: 0 1rem; }
    .hero { padding: 2rem 1rem 1.5rem; }
    footer { flex-direction: column; gap: 1rem; text-align: center; }
  }
  @media (max-width: 480px) {
    .features { grid-template-columns: 1fr; }
    .gods { grid-template-columns: repeat(3, 1fr); }
    .species-grid { grid-template-columns: 1fr; }
    .footer-links { gap: 1rem; flex-wrap: wrap; justify-content: center; }
  }
</style>
</head>
<body>

<nav class="portal-nav">
  <a href="/" class="portal-brand">__SERVER_ABBR__</a>
  <div class="portal-local">
    <a href="/">Home</a>
    <a href="/play/" class="play-link">&#9654; Play</a>
    <a href="/scores/">Leaderboard</a>
    <a href="/morgue/">Morgue</a>
    <a href="/ttyrec/">Recordings</a>
  </div>
</nav>

<!-- ── Hero ─────────────────────────────────────────────────────────────── -->
<div class="hero">
  <h1 class="hero-title">Dungeon Crawl Stone Soup</h1>
  <p class="hero-sub">Descend into the dungeon. Claim the Orb of Zot. Escape alive.</p>
</div>

<div class="content">

  <!-- ── Quick links ───────────────────────────────────────────────────── -->
  <div class="features">
    <a href="/play/" class="feature feature-play" style="text-decoration:none">
      <span class="feature-icon">&#9654;</span>
      <div class="feature-name">Enter the Dungeon</div>
      <p class="feature-desc">Begin your descent</p>
      <span class="feature-link">Play</span>
    </a>
    <a href="/scores/" class="feature" style="text-decoration:none">
      <span class="feature-icon">&#9760;</span>
      <div class="feature-name">Leaderboard</div>
      <p class="feature-desc">The bravest and the fallen</p>
      <span class="feature-link">View</span>
    </a>
    <a href="https://crawl.develz.org/info/" class="feature" style="text-decoration:none">
      <span class="feature-icon">&#9733;</span>
      <div class="feature-name">Wiki</div>
      <p class="feature-desc">Species, gods, and strategy</p>
      <span class="feature-link">Read</span>
    </a>
  </div>

  <!-- ── Live games ─────────────────────────────────────────────────── -->
  <div class="live-section">
    <div class="live-header">
      <h2 class="section-title">Currently Playing</h2>
      <span class="live-count" id="live-count"></span>
    </div>
    <div id="live-games">
      <div class="live-empty" id="live-empty"><span class="live-empty-icon">&#9760;</span>The dungeon is silent. <a href="/play/">Be the first to enter.</a></div>
    </div>
  </div>

  <!-- ── About ───────────────────────────────────────────────────────── -->
  <h2 class="section-title">What is DCSS?</h2>
  <div class="about-grid">
    <div class="about-block">
      <h3>The Game</h3>
      <p>
        Dungeon Crawl Stone Soup is a <em>roguelike adventure</em> — a dungeon
        filled with monsters, traps, treasures, and gods. Every run is
        procedurally generated. Death is permanent. Your goal: descend to
        <em>Zot:5</em>, seize the <em>Orb of Zot</em>, and escape alive.
      </p>
