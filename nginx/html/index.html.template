<script>
(function() {
  var games = {};
  var container = document.getElementById('live-games');
  var emptyMsg = document.getElementById('live-empty');
  var countEl = document.getElementById('live-count');
  var ws, retryDelay = 1000;

  function connect() {
    var proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
    ws = new WebSocket(proto + '//' + location.host + '/socket');

    ws.onopen = function() { retryDelay = 1000; };

    ws.onmessage = function(e) {
      var msg;
      try { msg = JSON.parse(e.data); } catch(_) { return; }

      if (msg.msg === 'lobby_clear') {
        games = {};
      } else if (msg.msg === 'lobby_entry') {
        games[msg.id] = msg;
        render();
      } else if (msg.msg === 'lobby_remove') {
        delete games[msg.id];
        render();
      } else if (msg.msg === 'lobby_complete') {
        render();
      }
    };

    ws.onclose = function() {
      setTimeout(connect, retryDelay);
      retryDelay = Math.min(retryDelay * 2, 30000);
    };
  }

  function formatDur(sec) {
    if (!sec) return '';
    var h = Math.floor(sec / 3600);
    var m = Math.floor((sec % 3600) / 60);
    if (h > 0) return h + 'h' + (m > 0 ? m + 'm' : '');
    return m + 'm';
  }

  function formatIdle(sec) {
    if (!sec || sec < 60) return '';
    var h = Math.floor(sec / 3600);
    var m = Math.floor((sec % 3600) / 60);
    if (h > 0) return h + 'h';
    return m + 'm';
  }

  function esc(s) {
    if (!s) return '';
    var d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function render() {
    var entries = Object.values(games);
    var n = entries.length;

    if (n === 0) {
      countEl.innerHTML = '';
      emptyMsg.style.display = 'block';
      var tbl = container.querySelector('table');
      if (tbl) tbl.remove();
      return;
    }

    countEl.innerHTML = '<span class="live-dot"></span>' + n + ' game' + (n !== 1 ? 's' : '');
    emptyMsg.style.display = 'none';

    entries.sort(function(a, b) { return (a.idle_time || 0) - (b.idle_time || 0); });

    var html = '<table class="live-table"><thead><tr>'
      + '<th>Player</th><th>Char</th><th>Place</th><th>Turn</th><th>Time</th>'
      + '<th>God</th><th>Milestone</th>'
      + '</tr></thead><tbody>';

    entries.forEach(function(g) {
      var watchUrl = '/play/#watch-' + encodeURIComponent(g.username);
      html += '<tr>'
        + '<td class="col-user"><a href="' + watchUrl + '" title="Watch ' + esc(g.username) + '">' + esc(g.username) + '</a>'
        + (g.spectator_count ? ' <span class="col-specs" title="Spectators">(' + g.spectator_count + ')</span>' : '') + '</td>'
        + '<td class="col-char">' + (g.xl ? 'L' + g.xl + ' ' : '') + esc(g.char) + '</td>'
        + '<td class="col-place">' + esc(g.place) + '</td>'
        + '<td class="col-turn">' + (g.turn || '') + '</td>'
        + '<td>' + formatDur(g.dur) + '</td>'
        + '<td class="col-god">' + esc(g.god) + '</td>'
        + '<td class="col-milestone">' + esc(g.milestone) + '</td>'
        + '</tr>';
    });

    html += '</tbody></table>';

    var tbl = container.querySelector('table');
    if (tbl) tbl.outerHTML = html;
    else container.insertAdjacentHTML('afterbegin', html);
  }

  connect();
})();
</script>
